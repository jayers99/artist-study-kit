# artist-study-kit — environment template
# Copy to .env and fill in real values. .env is gitignored (never commit secrets).
#
#   cp .env.example .env
#
# The scripts read os.environ directly, so load .env before running, e.g.:
#   uv run --env-file .env python skill/_run_stage5.py
# or export it into the shell:
#   set -a; source .env; set +a

# Firecrawl scrape API key (Stage 2 source fetching via scripts/firecrawl_fetch.py).
# Get one at https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-your-key-here
